APP_ENV=dev

POSTGRES_DB=carrot_stick
POSTGRES_USER=carrot_stick
POSTGRES_PASSWORD=carrot_stick

DATABASE_URL=postgresql+psycopg://carrot_stick:carrot_stick@postgres:5432/carrot_stick
JWT_SECRET=change-me-to-a-strong-secret-with-at-least-32-bytes
JWT_EXPIRES_MINUTES=43200
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Add explicit origins here for production or custom dev hosts.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional. If empty, frontend derives http://<current-host>:8000.
VITE_API_BASE_URL=
